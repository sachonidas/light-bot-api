# Database
DATABASE_URL="postgresql://luzbot:luzbot_dev@localhost:5432/luzbot"

# JWT
JWT_SECRET="change_this_secret_in_production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change_this_refresh_secret_in_production"
JWT_REFRESH_EXPIRES_IN="30d"

# ESIOS API (solicitar en esios.ree.es)
ESIOS_API_KEY="your_esios_api_key"
